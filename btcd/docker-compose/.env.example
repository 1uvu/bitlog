## ports:
# for mainnet 8333 8334
# for testnet 18555 18556
# for simnet 18333 18334
# for signet 38333 38334
## port for peer-to-peer network in mainnet
PORT_PEER=8333
## port for rpc in mainnet
PORT_RPC=8334
## ipv4 address
SUBNET_CIDR=172.16.0.0/24
SUBNET_ADDRESS=172.16.0.10
## image
IMAGE=bitlog/btcd:latest
## container name
CONTAINER_NAME=peer0.net0.mainnet
## hostname
HOSTNAME=peer0.net0.mainnet
## btcd root dir, include btcd.conf, log and data
BTCD_ROOT_DIR=./peers/peer-peer0.net0.mainnet/